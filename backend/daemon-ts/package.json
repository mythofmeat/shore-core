{
  "name": "shore-daemon-ts",
  "version": "0.0.0-phase8d",
  "description": "Shore daemon (TypeScript reimplementation). See REWRITE.md.",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run src/main.ts",
    "build": "bun build src/main.ts --compile --outfile dist/shore-daemon",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "smoketest": "bun scripts/handshake-smoketest.ts",
    "smoketest:compiled": "bun scripts/handshake-smoketest.ts ./dist/shore-daemon",
    "parity": "bun scripts/parity-check.ts parity-traces/handshake-empty.jsonl && bun scripts/parity-check.ts parity-traces/handshake-character.jsonl --fixture parity-traces/fixtures/handshake-character && bun scripts/parity-check-message-append.ts && bun scripts/parity-check-multi-turn.ts && bun scripts/parity-check-edit.ts && bun scripts/parity-check-delete.ts && bun scripts/parity-check-alt.ts && bun scripts/parity-check-commands.ts",
    "parity:compiled": "bun scripts/parity-check.ts parity-traces/handshake-empty.jsonl ./dist/shore-daemon && bun scripts/parity-check.ts parity-traces/handshake-character.jsonl ./dist/shore-daemon --fixture parity-traces/fixtures/handshake-character && bun scripts/parity-check-message-append.ts ./dist/shore-daemon && bun scripts/parity-check-multi-turn.ts ./dist/shore-daemon && bun scripts/parity-check-edit.ts ./dist/shore-daemon && bun scripts/parity-check-delete.ts ./dist/shore-daemon && bun scripts/parity-check-alt.ts ./dist/shore-daemon && bun scripts/parity-check-commands.ts ./dist/shore-daemon",
    "parity:commands": "bun scripts/parity-check-commands.ts",
    "parity:generation": "bun scripts/parity-check-generation.ts --baseline parity-traces/frozen/generation-basic.json",
    "parity:generation:compiled": "bun scripts/parity-check-generation.ts --ts ./dist/shore-daemon --baseline parity-traces/frozen/generation-basic.json",
    "parity:generation:cached": "bun scripts/parity-check-generation.ts --rust /usr/bin/shore-daemon --cache-ttl 1h",
    "parity:generation:cached:compiled": "bun scripts/parity-check-generation.ts --rust /usr/bin/shore-daemon --ts ./dist/shore-daemon --cache-ttl 1h",
    "parity:generation:openai": "bun scripts/parity-check-generation.ts --fixture parity-traces/fixtures/generation-openai-compatible --response parity-traces/llm-fixtures/generation-openai-compatible.json --baseline parity-traces/frozen/generation-openai-compatible.json",
    "parity:generation:openai:compiled": "bun scripts/parity-check-generation.ts --ts ./dist/shore-daemon --fixture parity-traces/fixtures/generation-openai-compatible --response parity-traces/llm-fixtures/generation-openai-compatible.json --baseline parity-traces/frozen/generation-openai-compatible.json",
    "parity:regen": "bun scripts/parity-check-regen.ts --rust /usr/bin/shore-daemon",
    "parity:regen:compiled": "bun scripts/parity-check-regen.ts --rust /usr/bin/shore-daemon --ts ./dist/shore-daemon",
    "parity:regen:cached": "bun scripts/parity-check-regen.ts --rust /usr/bin/shore-daemon --cache-ttl 1h",
    "parity:regen:cached:compiled": "bun scripts/parity-check-regen.ts --rust /usr/bin/shore-daemon --ts ./dist/shore-daemon --cache-ttl 1h",
    "parity:tool-loop": "bun scripts/parity-check-tool-loop.ts --rust /usr/bin/shore-daemon",
    "parity:tool-loop:compiled": "bun scripts/parity-check-tool-loop.ts --rust /usr/bin/shore-daemon --ts ./dist/shore-daemon",
    "parity:tool-loop:cached": "bun scripts/parity-check-tool-loop.ts --rust /usr/bin/shore-daemon --cache-ttl 1h",
    "parity:tool-loop:cached:compiled": "bun scripts/parity-check-tool-loop.ts --rust /usr/bin/shore-daemon --ts ./dist/shore-daemon --cache-ttl 1h",
    "parity:compaction": "bun scripts/parity-check-inline-compaction.ts --rust /usr/bin/shore-daemon",
    "parity:compaction:compiled": "bun scripts/parity-check-inline-compaction.ts --rust /usr/bin/shore-daemon --ts ./dist/shore-daemon",
    "parity:compaction:cached": "bun scripts/parity-check-inline-compaction.ts --rust /usr/bin/shore-daemon --cache-ttl 1h",
    "parity:compaction:cached:compiled": "bun scripts/parity-check-inline-compaction.ts --rust /usr/bin/shore-daemon --ts ./dist/shore-daemon --cache-ttl 1h",
    "parity:heartbeat-tick": "bun scripts/parity-check-heartbeat-tick.ts --rust /usr/bin/shore-daemon",
    "parity:heartbeat-tick:compiled": "bun scripts/parity-check-heartbeat-tick.ts --rust /usr/bin/shore-daemon --ts ./dist/shore-daemon",
    "parity:heartbeat-tick:cached": "bun scripts/parity-check-heartbeat-tick.ts --rust /usr/bin/shore-daemon --cache-ttl 1h",
    "parity:heartbeat-tick:cached:compiled": "bun scripts/parity-check-heartbeat-tick.ts --rust /usr/bin/shore-daemon --ts ./dist/shore-daemon --cache-ttl 1h",
    "parity:dreaming": "bun scripts/parity-check-dreaming.ts --rust /usr/bin/shore-daemon",
    "parity:dreaming:compiled": "bun scripts/parity-check-dreaming.ts --rust /usr/bin/shore-daemon --ts ./dist/shore-daemon",
    "parity:dreaming:cached": "bun scripts/parity-check-dreaming.ts --rust /usr/bin/shore-daemon --cache-ttl 1h",
    "parity:dreaming:cached:compiled": "bun scripts/parity-check-dreaming.ts --rust /usr/bin/shore-daemon --ts ./dist/shore-daemon --cache-ttl 1h",
    "parity:scheduled-dreaming": "bun scripts/parity-check-scheduled-dreaming.ts --rust /usr/bin/shore-daemon",
    "parity:scheduled-dreaming:compiled": "bun scripts/parity-check-scheduled-dreaming.ts --rust /usr/bin/shore-daemon --ts ./dist/shore-daemon",
    "parity:scheduled-dreaming:cached": "bun scripts/parity-check-scheduled-dreaming.ts --rust /usr/bin/shore-daemon --cache-ttl 1h",
    "parity:scheduled-dreaming:cached:compiled": "bun scripts/parity-check-scheduled-dreaming.ts --rust /usr/bin/shore-daemon --ts ./dist/shore-daemon --cache-ttl 1h",
    "parity:capture-commands": "bun scripts/capture-command.ts /usr/bin/shore-daemon --all",
    "capture-trace": "bun scripts/capture-rust-trace.ts /usr/bin/shore-daemon"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "croner": "^10.0.1",
    "dotenv": "^17.4.2",
    "openai": "^6.39.0",
    "smol-toml": "^1.6.1",
    "zod": "^3.23.0"
  }
}
