max_value = 1.0
step = 0.01
value = 0.4

[node name="Sep2" type="HSeparator" parent="ScrollContainer/Margin/VBox"]
layout_mode = 2

[node name="EffectsLabel" type="Label" parent="ScrollContainer/Margin/VBox"]
layout_mode = 2
text = "── Effects ──"

[node name="ScreenShakeToggle" type="CheckButton" parent="ScrollContainer/Margin/VBox"]
