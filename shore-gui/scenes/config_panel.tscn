[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/config_panel.gd" id="1"]

[node name="ConfigPanel" type="PanelContainer"]
custom_minimum_size = Vector2(340, 0)
anchors_preset = 3
anchor_left = 1.0
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = -360
offset_top = 10
offset_right = -10
offset_bottom = -10
grow_horizontal = 0
grow_vertical = 2
script = ExtResource("1")

[node name="ScrollContainer" type="ScrollContainer" parent="."]
layout_mode = 2

[node name="Margin" type="MarginContainer" parent="ScrollContainer"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/margin_left = 12
theme_override_constants/margin_top = 12
theme_override_constants/margin_right = 12
theme_override_constants/margin_bottom = 12

[node name="VBox" type="VBoxContainer" parent="ScrollContainer/Margin"]
layout_mode = 2
size_flags_horizontal = 3

[node name="Header" type="HBoxContainer" parent="ScrollContainer/Margin/VBox"]
layout_mode = 2

[node name="Title" type="Label" parent="ScrollContainer/Margin/VBox/Header"]
layout_mode = 2
text = "Effects Configuration"

[node name="Spacer" type="Control" parent="ScrollContainer/Margin/VBox/Header"]
layout_mode = 2
size_flags_horizontal = 3

[node name="CloseButton" type="Button" parent="ScrollContainer/Margin/VBox/Header"]
layout_mode = 2
text = "X"

[node name="Sep0" type="HSeparator" parent="ScrollContainer/Margin/VBox"]
layout_mode = 2

[node name="PresetLabel" type="Label" parent="ScrollContainer/Margin/VBox"]
layout_mode = 2
text = "Preset"

[node name="PresetOption" type="OptionButton" parent="ScrollContainer/Margin/VBox"]
layout_mode = 2
item_count = 2
popup/item_0/text = "Default"
popup/item_1/text = "Silent Shore"
popup/item_1/id = 1

[node name="Sep0a" type="HSeparator" parent="ScrollContainer/Margin/VBox"]
layout_mode = 2

[node name="ProfessionalMode" type="CheckButton" parent="ScrollContainer/Margin/VBox"]
layout_mode = 2
text = "Professional Mode (disable all)"

[node name="Sep1" type="HSeparator" parent="ScrollContainer/Margin/VBox"]
layout_mode = 2

[node name="ShadersLabel" type="Label" parent="ScrollContainer/Margin/VBox"]
layout_mode = 2
text = "── Shaders ──"

[node name="CRTToggle" type="CheckButton" parent="ScrollContainer/Margin/VBox"]
layout_mode = 2
button_pressed = true
text = "CRT Scanlines"

[node name="ScanlineLabel" type="Label" parent="ScrollContainer/Margin/VBox"]
layout_mode = 2
text = "  Scanline Intensity"

[node name="ScanlineSlider" type="HSlider" parent="ScrollContainer/Margin/VBox"]
layout_mode = 2
min_value = 0.0
max_value = 1.0
step = 0.01
value = 0.15

[node name="DistortionLabel" type="Label" parent="ScrollContainer/Margin/VBox"]
layout_mode = 2
text = "  Barrel Distortion"

[node name="DistortionSlider" type="HSlider" parent="ScrollContainer/Margin/VBox"]
layout_mode = 2
min_value = 0.0
max_value = 0.5
step = 0.005
value = 0.1

[node name="VignetteLabel" type="Label" parent="ScrollContainer/Margin/VBox"]
layout_mode = 2
text = "  Vignette"

[node name="VignetteSlider" type="HSlider" parent="ScrollContainer/Margin/VBox"]
layout_mode = 2
min_value = 0.0
max_value = 1.0
step = 0.01
value = 0.3

[node name="GlowToggle" type="CheckButton" parent="ScrollContainer/Margin/VBox"]
layout_mode = 2
button_pressed = true
text = "Glow Pulse"

[node name="GlowRadiusLabel" type="Label" parent="ScrollContainer/Margin/VBox"]
layout_mode = 2
text = "  Glow Radius"

[node name="GlowRadiusSlider" type="HSlider" parent="ScrollContainer/Margin/VBox"]
layout_mode = 2
min_value = 0.0
max_value = 10.0
step = 0.1
value = 3.0

[node name="VHSToggle" type="CheckButton" parent="ScrollContainer/Margin/VBox"]
layout_mode = 2
button_pressed = true
text = "VHS Artifacts"

[node name="StarfieldToggle" type="CheckButton" parent="ScrollContainer/Margin/VBox"]
layout_mode = 2
