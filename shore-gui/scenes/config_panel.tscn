[node name="Sep4" type="HSeparator" parent="ScrollContainer/Margin/VBox"]
layout_mode = 2

[node name="TextLabel" type="Label" parent="ScrollContainer/Margin/VBox"]
layout_mode = 2
text = "── Text ──"

[node name="FontLabel" type="Label" parent="ScrollContainer/Margin/VBox"]
layout_mode = 2
text = "Font"

[node name="FontOption" type="OptionButton" parent="ScrollContainer/Margin/VBox"]
layout_mode = 2
item_count = 8
popup/item_0/text = "default"
popup/item_1/text = "mono"
popup/item_1/id = 1
popup/item_2/text = "JetBrains Mono"
