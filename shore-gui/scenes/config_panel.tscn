[node name="EnterSendsToggle" type="CheckButton" parent="ScrollContainer/Margin/VBox"]
layout_mode = 2
text = "Enter sends message"

[connection signal="pressed" from="ScrollContainer/Margin/VBox/Header/CloseButton" to="." method="_on_close"]
[connection signal="item_selected" from="ScrollContainer/Margin/VBox/PresetOption" to="." method="_on_preset_selected"]
[connection signal="toggled" from="ScrollContainer/Margin/VBox/ProfessionalMode" to="." method="_on_professional_mode"]
[connection signal="toggled" from="ScrollContainer/Margin/VBox/CRTToggle" to="." method="_on_toggle" binds= ["crt_enabled"]]
[connection signal="toggled" from="ScrollContainer/Margin/VBox/GlowToggle" to="." method="_on_toggle" binds= ["glow_enabled"]]
[connection signal="toggled" from="ScrollContainer/Margin/VBox/VHSToggle" to="." method="_on_toggle" binds= ["vhs_enabled"]]
[connection signal="toggled" from="ScrollContainer/Margin/VBox/StarfieldToggle" to="." method="_on_toggle" binds= ["starfield_enabled"]]
[connection signal="toggled" from="ScrollContainer/Margin/VBox/ScreenShakeToggle" to="." method="_on_toggle" binds= ["screen_shake_enabled"]]
[connection signal="toggled" from="ScrollContainer/Margin/VBox/FireCursorToggle" to="." method="_on_toggle" binds= ["fire_cursor_enabled"]]
[connection signal="toggled" from="ScrollContainer/Margin/VBox/WPMToggle" to="." method="_on_toggle" binds= ["wpm_enabled"]]
[connection signal="toggled" from="ScrollContainer/Margin/VBox/AudioToggle" to="." method="_on_toggle" binds= ["audio_enabled"]]
[connection signal="toggled" from="ScrollContainer/Margin/VBox/TypingSoundsToggle" to="." method="_on_toggle" binds= ["typing_sounds_enabled"]]
[connection signal="toggled" from="ScrollContainer/Margin/VBox/AmbientToggle" to="." method="_on_toggle" binds= ["ambient_enabled"]]
[connection signal="value_changed" from="ScrollContainer/Margin/VBox/ScanlineSlider" to="." method="_on_slider" binds= ["crt_scanline_intensity"]]
[connection signal="value_changed" from="ScrollContainer/Margin/VBox/DistortionSlider" to="." method="_on_slider" binds= ["crt_distortion_intensity"]]
[connection signal="value_changed" from="ScrollContainer/Margin/VBox/VignetteSlider" to="." method="_on_slider" binds= ["crt_vignette_intensity"]]
[connection signal="value_changed" from="ScrollContainer/Margin/VBox/GlowRadiusSlider" to="." method="_on_slider" binds= ["glow_radius"]]
[connection signal="value_changed" from="ScrollContainer/Margin/VBox/StarDensitySlider" to="." method="_on_slider" binds= ["star_density"]]
[connection signal="value_changed" from="ScrollContainer/Margin/VBox/ShakeScaleSlider" to="." method="_on_slider" binds= ["shake_scale"]]
[connection signal="value_changed" from="ScrollContainer/Margin/VBox/MasterVolumeSlider" to="." method="_on_slider" binds= ["master_volume_db"]]
[connection signal="value_changed" from="ScrollContainer/Margin/VBox/AmbientVolumeSlider" to="." method="_on_slider" binds= ["ambient_volume_db"]]
[connection signal="item_selected" from="ScrollContainer/Margin/VBox/FontOption" to="." method="_on_font_selected"]
[connection signal="value_changed" from="ScrollContainer/Margin/VBox/FontSizeSlider" to="." method="_on_font_size_changed"]
[connection signal="item_selected" from="ScrollContainer/Margin/VBox/LCDFilterOption" to="." method="_on_lcd_filter_selected"]
[connection signal="toggled" from="ScrollContainer/Margin/VBox/EnterSendsToggle" to="." method="_on_enter_sends_toggled"]
