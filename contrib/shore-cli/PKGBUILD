# Maintainer: eshen
pkgname=shore-cli
pkgver=1.8.5
pkgrel=1
pkgdesc='Persistent AI character engine — CLI'
arch=('x86_64')
url='https://github.com/mythofmeat/shore-core'
license=('custom')
depends=('gcc-libs')
makedepends=('cargo' 'git')
provides=('shore-cli')
conflicts=('shore-cli' 'shore-core' 'shore-git')
source=("shore-core::git+ssh://git@github.com/mythofmeat/shore-core.git")
options=('!lto' '!debug' 'strip')
sha256sums=('SKIP')

prepare() {
    cd shore-core
    export RUSTUP_TOOLCHAIN=stable
    cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
    cd shore-core
    export RUSTUP_TOOLCHAIN=stable
    export CARGO_TARGET_DIR=target
    cargo build --release --frozen -p shore-cli
}

package() {
    cd shore-core

    install -Dm755 target/release/shore "$pkgdir/usr/bin/shore"

    install -Dm644 contrib/shore-notify.service \
        "$pkgdir/usr/lib/systemd/user/shore-notify.service"

    install -dm755 "$pkgdir/usr/share/fish/vendor_completions.d"
    install -dm755 "$pkgdir/usr/share/bash-completion/completions"
    install -dm755 "$pkgdir/usr/share/zsh/site-functions"
    target/release/shore completions fish > "$pkgdir/usr/share/fish/vendor_completions.d/shore.fish"
    target/release/shore completions bash > "$pkgdir/usr/share/bash-completion/completions/shore"
    target/release/shore completions zsh  > "$pkgdir/usr/share/zsh/site-functions/_shore"
}
