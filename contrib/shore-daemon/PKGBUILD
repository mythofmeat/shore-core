# Maintainer: eshen
pkgname=shore-daemon
pkgver=1.8.5
pkgrel=1
# The crate version was reset 16.1.0 -> 0.1.0 (cargo-semver-checks had inflated
# it into the double digits). epoch=1 keeps `1:0.1.0` sorting above the old
# `16.1.0` so installed packages still upgrade across the reset instead of
# treating it as a downgrade. The repo-arch build only rewrites pkgver from the
# release-plz tag and leaves epoch untouched.
epoch=1
pkgdesc='Persistent AI character engine — daemon'
arch=('x86_64')
url='https://github.com/mythofmeat/shore-core'
license=('custom')
# bun is a runtime dep: the LLM sidecar ships as a bundled JS script with a
# `#!/usr/bin/env bun` shebang rather than a ~70MB --compile binary (the
# embedded Bun runtime dwarfed the ~1.4MB of actual code). Trades the
# self-contained binary for a shared bun package.
# git is a runtime dep: the daemon shells out to it for workspace memory
# history (compaction/dreaming commits) and the exec tool.
depends=('gcc-libs' 'openssl' 'bun' 'git')
makedepends=('bun' 'cargo' 'git')
provides=('shore-daemon')
conflicts=('shore-daemon' 'shore-core' 'shore-git')
source=("shore-core::git+ssh://git@github.com/mythofmeat/shore-core.git")
options=('!lto' '!debug' 'strip')
sha256sums=('SKIP')

prepare() {
    cd shore-core
    export RUSTUP_TOOLCHAIN=stable
    cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
    cd shore-core
    export RUSTUP_TOOLCHAIN=stable
    export CARGO_TARGET_DIR=target
    cargo build --release --frozen -p shore-daemon
    cd backend/llm-sidecar
    bun install --frozen-lockfile
    bun run build
}

package() {
    cd shore-core

    install -Dm755 target/release/shore-daemon "$pkgdir/usr/bin/shore-daemon"
    # Kept out of /usr/bin on purpose: the daemon supervises this directly and
    # locates it via SHORE_LLM_SIDECAR_BIN, so no user (or the AI's bash tool)
    # should be able to run it by name off $PATH.
    install -Dm755 backend/llm-sidecar/dist/shore-llm-sidecar \
        "$pkgdir/usr/lib/shore/shore-llm-sidecar"

    install -Dm644 contrib/shore-daemon.service \
        "$pkgdir/usr/lib/systemd/user/shore-daemon.service"

    install -Dm644 examples/config.toml \
        "$pkgdir/usr/share/doc/shore/config.toml.example"
    install -Dm644 examples/models.toml \
        "$pkgdir/usr/share/doc/shore/models.toml.example"
    install -Dm644 examples/client.toml \
        "$pkgdir/usr/share/doc/shore/client.toml.example"
}
