# Maintainer: eshen
pkgname=shore-daemon-ts
pkgver=0.0.0_phase8d
pkgrel=1
pkgdesc='TypeScript/Bun preview of the persistent Shore daemon'
arch=('x86_64')
url='https://github.com/mythofmeat/shore-core'
license=('custom')
depends=('gcc-libs' 'icu')
makedepends=('bun' 'git')
provides=('shore-daemon-ts')
conflicts=('shore-daemon-ts')
source=("shore-core::git+ssh://git@github.com/mythofmeat/shore-core.git")
options=('!lto' '!debug' 'strip')
sha256sums=('SKIP')

prepare() {
    cd shore-core/backend/daemon-ts
    bun install --frozen-lockfile
}

build() {
    cd shore-core/backend/daemon-ts
    bun run build
}

check() {
    cd shore-core/backend/daemon-ts
    bun run typecheck
    bun test
    bun run smoketest:compiled
}

package() {
    cd shore-core

    install -Dm755 backend/daemon-ts/dist/shore-daemon \
        "$pkgdir/usr/bin/shore-daemon-ts"

    install -Dm644 contrib/shore-daemon-ts.service \
        "$pkgdir/usr/lib/systemd/user/shore-daemon-ts.service"

    install -Dm644 backend/daemon-ts/README.md \
        "$pkgdir/usr/share/doc/shore-daemon-ts/README.md"
    install -Dm644 REWRITE.md \
        "$pkgdir/usr/share/doc/shore-daemon-ts/REWRITE.md"
}
